# Static assets — cached for 24 hours (filenames don't change between deploys)
/favicon.ico
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=86400

/favicon-96x96.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/web-app-manifest-192x192.png
  Cache-Control: public, max-age=86400

/web-app-manifest-512x512.png
  Cache-Control: public, max-age=86400

# Webmanifest revalidates hourly so PWA installs pick up icon/name changes promptly
/site.webmanifest
  Cache-Control: public, max-age=3600
