# Database Configuration
# PostgreSQL connection string from Neon (https://neon.tech)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL='postgresql://user:password@host.neon.tech/database?sslmode=require'

# WorkOS User Management Configuration (https://workos.com/docs/user-management)
# WorkOS provides authentication and user management
# Get these values from your WorkOS dashboard (https://dashboard.workos.com)

# Secret API key for server-side operations (keep secure, never expose to client)
# Starts with sk_live_ (production) or sk_test_ (development)
WORKOS_API_KEY='sk_live_your_api_key_here'

# Client ID for your WorkOS application
# Starts with client_
WORKOS_CLIENT_ID='client_your_client_id_here'

# Organization ID for this project (all users will be created in this organization)
# Starts with org_
WORKOS_ORGANIZATION_ID='org_your_organization_id_here'

# Strong password for encrypting session cookies (32+ characters)
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD='your-32-plus-character-random-string-here'

# Cloudflare R2 Storage Configuration (https://developers.cloudflare.com/r2/)
# Required for file uploads (images for hikes and camping sites)
# Create a bucket and API token in: Cloudflare Dashboard > R2

# Your Cloudflare Account ID (visible in right sidebar of any Cloudflare dashboard page)
R2_ACCOUNT_ID='your-cloudflare-account-id'

# R2 API Token credentials
# Create at: Cloudflare Dashboard > R2 > Manage R2 API Tokens (Object Read & Write)
R2_ACCESS_KEY_ID='your-r2-access-key-id'
R2_SECRET_ACCESS_KEY='your-r2-secret-access-key'

# R2 bucket name (create at Cloudflare Dashboard > R2 > Create Bucket)
R2_BUCKET_NAME='adventure-spark-files'

# Public URL for the R2 bucket
# Enable public access on the bucket to get this URL
# Format: https://pub-<hash>.r2.dev  OR  https://your-custom-domain.com
R2_PUBLIC_URL='https://pub-yourhash.r2.dev'

# Optional: Override R2 endpoint for local development (e.g. MinIO)
# R2_ENDPOINT_OVERRIDE='http://localhost:9000'

# Vercel Edge Config (https://vercel.com/docs/storage/edge-config)
# Used for feature flags (e.g. backpacking section preview)
# Get the connection string from your Vercel dashboard under Storage > Edge Config
EDGE_CONFIG='https://edge-config.vercel.com/ecfg_xxx?token=yyy'

# Vercel Flags SDK secret (https://flags-sdk.dev/docs/api-reference/frameworks/sveltekit)
# Required for Vercel Toolbar integration and flag override encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
FLAGS_SECRET='your-flags-secret-here'

# Application Environment
# Use 'development' for local development, 'production' for deployed environments
NODE_ENV='development'

# Optional: Application URL
# Used for generating absolute URLs in emails, redirects, etc.
# PUBLIC_APP_URL='http://localhost:5173'
