# Playwright E2E Test Environment
# Copy to .env.test and fill in real values. Never commit .env.test.

# Regular test user (must exist in your WorkOS dev org)
TEST_USER_EMAIL=test-user@example.com
TEST_USER_PASSWORD=

# Admin test user (must exist in your WorkOS dev org with admin role)
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=

# UUIDs of approved content in your dev database for read/edit tests
TEST_HIKE_ID=
TEST_CAMPING_ID=
