{
  "name": "adventures",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev --mode dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:r2": "tsx scripts/migrate-r2.ts",
    "set-admin": "tsx scripts/set-admin.ts",
    "seed:hikes": "tsx scripts/seed-hikes.ts",
    "seed:camping": "tsx scripts/seed-camping.ts",
    "seed:backpacking": "tsx scripts/seed-backpacking.ts",
    "seed:councils": "tsx scripts/seed-councils.ts",
    "secrets:upload:prod": "node scripts/upload-secrets.cjs .env production",
    "secrets:upload:preview": "node scripts/upload-secrets.cjs .env.dev preview",
    "deploy:prod": "npm run build && wrangler pages deploy",
    "deploy:preview": "npm run build && wrangler pages deploy --branch preview",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:e2e:headed": "dotenv -e .env.test -- playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ci": "playwright test"
  },
  "devDependencies": {
    "@ernane/svelte-star-rating": "^1.1.9",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "happy-dom": "^20.0.11",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tslib": "^2.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@neondatabase/neon-js": "^0.1.0-beta.18",
    "@neondatabase/serverless": "^1.0.2",
    "@workos-inc/node": "^7.77.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "leaflet": "^1.9.4",
    "lucide-svelte": "^0.575.0",
    "obscenity": "^0.4.5"
  }
}
